    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "apexcharts": "^4.5.0",
    "better-auth": "^1.6.23",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
